@model IEnumerable<EventFlow.Application.DTOs.VisitaTecnica.VisitaTecnicaDto>

<h1>Visitas Técnicas</h1>

<a asp-action="Create"
   class="btn btn-primary mb-3">
    Nova Visita
</a>

<table class="table">

    <thead>
        <tr>
            <th>Data</th>
            <th>Responsável</th>
            <th></th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.DataAgendada</td>
                <td>@item.Responsavel</td>
                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning">
                        Editar
                    </a>

                </td>
            </tr>
        }

    </tbody>

</table>