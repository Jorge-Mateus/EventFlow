@model EventFlow.Application.DTOs.EquipeEvento.AtualizarEquipeEventoDto

<h1>Editar Equipe</h1>

<form asp-action="Edit" method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label>Colaborador</label>

        <select asp-for="ColaboradorId"
                asp-items="ViewBag.Colaboradores"
                class="form-select">
        </select>
    </div>

    <div class="mb-3">
        <label>Valor</label>

        <input asp-for="ValorPagamento"
               class="form-control" />
    </div>

    <button class="btn btn-success">
        Atualizar
    </button>

</form>