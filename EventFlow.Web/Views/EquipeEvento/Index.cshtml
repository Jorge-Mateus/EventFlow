@model IEnumerable<EventFlow.Application.DTOs.Evento.EventoDto>

<h1>Equipe por Evento</h1>

<table class="table table-bordered">

    <thead>
        <tr>
            <th>Evento</th>
            <th>Data</th>
            <th>Ação</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var evento in Model)
        {
            <tr>
                <td>@evento.Nome</td>
                <td>@evento.DataEvento.ToString("dd/MM/yyyy")</td>

                <td>

                    @if (evento.TemEquipe)
                    {
                        <a asp-action="Edit"
                           asp-route-eventoId="@evento.Id"
                           class="btn btn-warning">
                            Editar Equipe
                        </a>
                    }
                    else
                    {
                        <a asp-action="Create"
                           asp-route-eventoId="@evento.Id"
                           class="btn btn-success">
                            Montar Equipe
                        </a>
                    }

                </td>
            </tr>
        }

    </tbody>

</table>