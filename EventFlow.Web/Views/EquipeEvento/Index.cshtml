@model IEnumerable<EventFlow.Application.DTOs.EquipeEvento.EquipeEventoDto>

<h1>Equipe por Evento</h1>

<a asp-action="Create"
   class="btn btn-success mb-3">
    Montar Equipe
</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Valor</th>
            <th>Ações</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ValorPagamento.ToString("C")</td>

                <td>
                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <form asp-action="Delete"
                          method="post"
                          style="display:inline;">
                        <input type="hidden"
                               name="id"
                               value="@item.Id" />

                        <button class="btn btn-danger btn-sm">
                            Excluir
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>