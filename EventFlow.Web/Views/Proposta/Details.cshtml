@model EventFlow.Application.DTOs.Proposta.PropostaDetalheDto

<h1>Proposta</h1>

<div class="mb-4">

    <p>
        <strong>Status:</strong>
        @Model.Status
    </p>

    <p>
        <strong>Total:</strong>
        @Model.ValorTotal.ToString("C")
    </p>

</div>

<h3>Categorias</h3>

@foreach (var categoria in Model.Categorias)
{
    <div class="card mb-4">

        <div class="card-header d-flex justify-content-between">

            <strong>
                Categoria
            </strong>

            <strong>
                @categoria.Valor.ToString("C")
            </strong>

        </div>

        <div class="card-body">

            @if (categoria.Itens.Any())
            {
                <ul class="mb-0">

                    @foreach (var item in categoria.Itens)
                    {
                        <li>
                            @item.Descricao
                        </li>
                    }

                </ul>
            }
            else
            {
                <p class="text-muted">
                    Nenhum detalhe cadastrado.
                </p>
            }

        </div>

    </div>
}

<a class="btn btn-success">
    Adicionar Categoria
</a>