@model EventFlow.Application.DTOs.Cliente.CriarClienteDto

<h1>Novo Cliente</h1>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label>Nome</label>

        <input asp-for="Nome"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Telefone</label>

        <input asp-for="Telefone"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email</label>

        <input asp-for="Email"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-success">
        Salvar
    </button>

</form>