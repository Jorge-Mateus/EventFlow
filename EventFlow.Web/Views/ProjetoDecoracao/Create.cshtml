@model EventFlow.Application.DTOs.ProjetoDecoracao.CriarProjetoDecoracaoDto

@{
    ViewData["Title"] = "Novo Projeto 3D";
}

<div class="container">

    <h1 class="mb-4">
        Novo Projeto 3D
    </h1>

    <form asp-action="Create"
          method="post"
          enctype="multipart/form-data">

        <div class="mb-3">

            <label class="form-label">
                Proposta
            </label>

            <select asp-for="PropostaId"
                    asp-items="ViewBag.Propostas"
                    class="form-select">

                <option value="">
                    Selecione uma proposta
                </option>

            </select>

        </div>

        <div class="mb-3">

            <label asp-for="Nome"
                   class="form-label">
                Nome do Projeto
            </label>

            <input asp-for="Nome"
                   class="form-control" />

        </div>

        <div class="mb-3">

            <label asp-for="Observacoes"
                   class="form-label">
                Observações
            </label>

            <textarea asp-for="Observacoes"
                      class="form-control"
                      rows="4">
            </textarea>

        </div>

        <div class="mb-4">

            <label class="form-label">
                Arquivo do Projeto
            </label>

            <input type="file"
                   name="arquivo"
                   class="form-control" />

            <small class="text-muted">
                PDF, imagem, render 3D ou planta baixa
            </small>

        </div>

        <div class="d-flex gap-2">

            <button type="submit"
                    class="btn btn-success">
                Salvar Projeto
            </button>

            <a asp-action="Index"
               class="btn btn-secondary">
                Cancelar
            </a>

        </div>

    </form>

</div>