@model EventFlow.Application.DTOs.CategoriaOrcamento.CriarCategoriaOrcamentoDto

@{
    ViewData["Title"] = "Nova Categoria";
}

<h1>Nova Categoria</h1>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label">
            Nome
        </label>

        <input asp-for="Nome"
               class="form-control" />
    </div>

    <button type="submit"
            class="btn btn-success">
        Salvar
    </button>

</form>