@model EventFlow.Application.DTOs.Colaborador.AtualizarColaboradorDto

<h1>Editar Colaborador</h1>

<form asp-action="Edit" method="post">

    <input asp-for="Id" type="hidden" />

    <div class="mb-3">
        <label>Nome</label>
        <input asp-for="Nome" class="form-control" />
    </div>

    <div class="mb-3">
        <label>CPF</label>
        <input asp-for="CPF" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Telefone</label>
        <input asp-for="Telefone" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Pix</label>
        <input asp-for="Pix" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Função</label>

        <select asp-for="FuncaoId"
                asp-items="ViewBag.Funcoes"
                class="form-select">
        </select>
    </div>

    <button class="btn btn-success">
        Atualizar
    </button>

</form>